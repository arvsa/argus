DOMAIN=localhost
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local

PROJECT_NAME="argus"
STACK_NAME=argus-dev

BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Emails (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

SENTRY_DSN=

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_PINGSVC=pingsvc
DOCKER_IMAGE_FRONTEND=frontend

# Frontend image stage: dev = hot-reload Vite on 5173 (local default),
# prod = static nginx build on 80. Production deploys set both.
# FRONTEND_TARGET=prod
# FRONTEND_PORT=80

# Selects which docker compose stack scripts/run.sh brings up: "client" is a
# local zone (backend + redis + pingsvc), "server" is a central argus-server
# (backend only, no local ping pipeline). See README.md.
ROLE=client

MYSQL_SERVER=db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=changethis
MYSQL_DATABASE=argus

REDIS_URL="redis://redis:6379/0"
CHANNEL=pings:events
STATE_HASH=pings:state

# ── Multi-zone client/server (optional, all empty/unset = current
# single-stack behavior unchanged). See README.md and development.md for
# the full argus-client / argus-server walkthrough.
#
# pingsvc (argus-client) -- set ARGUS_ROLE=both to also run the exporter
# ARGUS_ROLE=pingsvc
# ARGUS_ZONE_ID=default
# ARGUS_TENANT_ID=default
# ARGUS_S3_BUCKET=
# ARGUS_S3_REGION=us-east-1
# ARGUS_S3_ENDPOINT=
# ARGUS_S3_ACCESS_KEY=
# ARGUS_S3_SECRET_KEY=
# ARGUS_SIGNING_KEY_PATH=
#
# backend (argus-server) -- set S3_BUCKET to enable the ingestion task
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# INGESTION_INTERVAL_SECONDS=60
# STALENESS_THRESHOLD_SECONDS=120

# pingsvc target hot-reload (optional -- empty ARGUS_BACKEND_URL on the
# pingsvc side disables it). PINGSVC_SYNC_TOKEN (backend) and
# ARGUS_PINGSVC_SYNC_TOKEN (pingsvc) must be the same value, same as
# MYSQL_ROOT_PASSWORD is shared between db and backend.
# PINGSVC_SYNC_TOKEN=changethis
# ARGUS_PINGSVC_SYNC_TOKEN=changethis
# ARGUS_BACKEND_URL=
# ARGUS_TARGET_SYNC_INTERVAL_SECONDS=30
